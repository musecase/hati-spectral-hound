# Copy to .env for local use. Never commit .env.
# HATI reads these values from the process environment; it does not parse
# .env automatically, which avoids adding a dependency to the foundation.
HATI_CAMERA_USERNAME=
HATI_CAMERA_PASSWORD=
OPENAI_API_KEY=
HATI_TUYA_DEVICE_NAME=
HATI_TELEGRAM_BOT_TOKEN=
HATI_TELEGRAM_CHAT_ID=
